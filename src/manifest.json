{
    "name": "YouTube Video Ends At",
    "description": "Displays the end time of videos on YouTube.",
    "version": "1.2.1",
    "manifest_version": 3,
    "browser_specific_settings": {
        "gecko": {
            "id": "video-ends-at@imgalvin.me",
            "data_collection_permissions": {
                "required": [
                    "none"
                ]
            }
        }
    },
    "content_scripts": [
        {
            "matches": [
                "*://www.youtube.com/*"
            ],
            "js": [
                "index.js"
            ]
        }
    ],
    "icons": {
        "16": "imgs/icon-16.png",
        "32": "imgs/icon-32.png",
        "48": "imgs/icon-48.png",
        "128": "imgs/icon-128.png"
    }
}